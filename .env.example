# Backend API origin (without /api/v1; the app appends /api/v1 automatically).
NEXT_PUBLIC_API_BASE_URL=https://zikel-solutions-be-kpotja.fly.dev

# App URL used for generating invite links (e.g. https://app.zikel.com).
# Falls back to https://app.zikel.com if not set. Must match the deployed frontend origin.
NEXT_PUBLIC_APP_URL=

# Optional: external legal pages. If omitted, app falls back to /terms and /privacy routes.
NEXT_PUBLIC_TERMS_URL=
NEXT_PUBLIC_PRIVACY_URL=
